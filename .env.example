# Copy to .env and fill in real values. .env is gitignored.

# Telegram bot — get a token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
# Random 32+ char string. Used in the webhook URL and as a header secret.
# Generate with: python -c 'import secrets; print(secrets.token_urlsafe(32))'
TELEGRAM_WEBHOOK_SECRET=
# Your Telegram user id (numeric). DM @userinfobot once to get yours. Leaving
# this blank ALLOWS ANY USER to use the bot — only do that for local testing.
ALLOWED_TELEGRAM_USER_ID=

# Groq API — https://console.groq.com/keys (used for speech-to-text)
GROQ_API_KEY=
GROQ_STT_MODEL=whisper-large-v3-turbo

# Mistral API — https://console.mistral.ai/api-keys (used for translation + analysis)
# Free tier: 1B tokens/month, 1 RPS — fine for personal use.
MISTRAL_API_KEY=
MISTRAL_LLM_MODEL=mistral-large-latest

# Google Cloud TTS — either GOOGLE_APPLICATION_CREDENTIALS (path to JSON)
# or GOOGLE_TTS_API_KEY (simpler, single string)
GOOGLE_TTS_API_KEY=
GOOGLE_TTS_VOICE=it-IT-Chirp3-HD-Aoede
GOOGLE_TTS_LANGUAGE=it-IT

# App config
DATA_DIR=./data
# Data lives in Firestore (production) — no DATABASE_URL needed. For Firestore auth,
# locally run: gcloud auth application-default login. On Cloud Run, the runtime SA.
# GCP_PROJECT is auto-detected from ADC; override here if you have multiple projects.
GCP_PROJECT=
FIRESTORE_DATABASE=(default)
PUBLIC_BASE_URL=http://localhost:8000
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# Source/target languages (override if you switch from English -> Italian)
SOURCE_LANG=en
TARGET_LANG=it
TARGET_LANG_NAME=Italian

# === Cloud Run deploy (used by scripts/deploy_cloud_run.sh) ===
PROJECT_ID=
REGION=us-central1
SERVICE=language-learner
# Must be GLOBALLY unique on GCS. Suggestion: <yourhandle>-language-learner-audio
GCS_BUCKET=
